# Netlify _headers — security and caching policy
# Apply to all paths

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Long cache for branded images (they rarely change; cache busts via filename if they do)
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Short cache with revalidation for CSS and JS (they update with deploys)
/style.css
  Cache-Control: public, max-age=3600, must-revalidate

/nav.js
  Cache-Control: public, max-age=3600, must-revalidate

# HTML files: revalidate on every visit so deploys take effect immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate
